# ============================================================
# Project outputs and large assets
# ============================================================

# Data lake (raw/processed/metadata) is local-only
# Keep only directory placeholders when needed.
data/**
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/metadata/.gitkeep
!data/processed/manifests/.gitkeep
!data/processed/annotations/.gitkeep

# Experiment outputs
runs/**
!runs/.gitkeep
!runs/_registry.csv

# Final artifacts
artifacts/**
!artifacts/.gitkeep
!artifacts/best_models/.gitkeep
!artifacts/submissions/.gitkeep

# Personal playground
playground/**
!playground/.gitkeep

# Model binaries / weights
*.pt
*.pth
*.onnx
*.weights

# ============================================================
# Python / tooling
# ============================================================
__pycache__/
*.py[cod]
venv/
.venv/
env/
dist/
build/
*.egg-info/

# Notebooks / IDE
.ipynb_checkpoints/
.vscode/
.idea/
.DS_Store
Thumbs.db

# ML tool outputs
yolo_settings.json
.ultralytics/
wandb/
mlruns/
lightning_logs/
*.log
nohup.out

# Local assistant caches
.claude/
**/.claude/
claude*.log
**/claude*.log
**/*claude*cache*
